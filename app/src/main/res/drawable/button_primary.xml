<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <!-- Sombra -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#2A5280"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
            <!-- Botão pressionado -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#2E5C8A"
                        android:endColor="#3A72B0"
                        android:type="linear"/>
                    <corners android:radius="16dp"/>
                    <stroke android:width="3dp" android:color="#FFB84D"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- Sombra -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1A3A5A"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
            <!-- Botão normal -->
            <item android:bottom="6dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#4A8FD0"
                        android:endColor="#3A72B0"
                        android:type="linear"/>
                    <corners android:radius="16dp"/>
                    <stroke android:width="3dp" android:color="#FFD700"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>