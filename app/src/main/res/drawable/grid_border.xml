<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow externo -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFB84D"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Borda laranja -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF8C00"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <!-- Borda interna clara -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFA500"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- Fundo interno -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#F5F5DC"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</layer-list>