<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#6B3410"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#8B4513"
                        android:endColor="#A0522D"
                        android:type="linear"/>
                    <corners android:radius="16dp"/>
                    <stroke android:width="3dp" android:color="#FFD700"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#4A2C2A"/>
                    <corners android:radius="16dp"/>
                </shape>
            </item>
            <item android:bottom="6dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#A0522D"
                        android:endColor="#8B4513"
                        android:type="linear"/>
                    <corners android:radius="16dp"/>
                    <stroke android:width="3dp" android:color="#FFB84D"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>