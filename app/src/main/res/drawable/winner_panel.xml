<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow dourado -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFD700"/>
            <corners android:radius="28dp"/>
        </shape>
    </item>
    <!-- Borda brilhante -->
    <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFA500"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <!-- Painel interno -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#FFF8DC"
                android:endColor="#F5DEB3"
                android:type="linear"/>
            <corners android:radius="20dp"/>
            <stroke android:width="3dp" android:color="#FF8C00"/>
        </shape>
    </item>
</layer-list>