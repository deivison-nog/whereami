<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="24dp">

    <!-- Logo Pequeno -->
    <LinearLayout
        android:id="@+id/logoLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/logo_bg"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ONDE"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:shadowColor="#000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="2"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESTOU?"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#00BFFF"
            android:shadowColor="#000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="2"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center"/>
    </LinearLayout>

    <!-- Painel do IP (Apenas para Servidor) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ipPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/waiting_panel"
        android:padding="20dp"
        android:elevation="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/logoLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tvIpLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡 SEU IP LOCAL:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#8B4513"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.0.100"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FF8C00"
            android:fontFamily="monospace"
            android:shadowColor="#FFFFFF"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            app:layout_constraintTop_toBottomOf="@id/tvIpLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvIpInstruction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="👇 Compartilhe este IP com seu oponente"
            android:textSize="13sp"
            android:textColor="#A0522D"
            android:textStyle="italic"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tvIpAddress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- Container de Botões -->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvIpInstruction"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp">

            <!-- Botão Copiar IP -->
            <Button
                android:id="@+id/btnCopyIp"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="📋 COPIAR"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_primary"
                android:elevation="4dp"
                android:layout_marginEnd="8dp"/>

            <!-- Botão Compartilhar IP -->
            <Button
                android:id="@+id/btnShareIp"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:text="📤 ENVIAR"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_primary"
                android:elevation="4dp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Painel de Espera -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/waitingPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/waiting_panel"
        android:padding="32dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="400dp">

        <!-- Ícone de Loading -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="80sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:indeterminate="true"
            android:indeterminateTint="#FF8C00"
            app:layout_constraintTop_toBottomOf="@id/tvIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <!-- Status Text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aguardando oponente..."
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#8B4513"
            android:textAlignment="center"
            android:shadowColor="#FFFFFF"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Por favor, aguarde... ⏳"
            android:textSize="16sp"
            android:textColor="#A0522D"
            android:textStyle="italic"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tvStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Dica no Rodapé -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tipPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/title_bg"
        android:padding="16dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="0dp">

        <TextView
            android:id="@+id/tvTipTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 DICA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvTipText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Certifique-se de estar na mesma rede WiFi"
            android:textSize="13sp"
            android:textColor="#FFF8DC"
            android:textAlignment="center"
            app:layout_constraintTop_toBottomOf="@id/tvTipTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>