<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/waiting_panel"
    android:padding="32dp">

    <!-- Ícone de Desconexão -->
    <TextView
        android:id="@+id/tvDisconnectIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚠️"
        android:textSize="80sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/tvDisconnectTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OPONENTE DESCONECTOU"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FF5252"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="3"
        android:fontFamily="sans-serif-black"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvDisconnectIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Mensagem -->
    <TextView
        android:id="@+id/tvDisconnectMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="O oponente saiu do jogo.\nA partida foi encerrada."
        android:textSize="16sp"
        android:textColor="#8B4513"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvDisconnectTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Botão OK -->
    <Button
        android:id="@+id/btnDisconnectOk"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="OK"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_primary"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDisconnectMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>